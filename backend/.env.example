PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/face_recognition_app
CLIENT_ORIGIN=http://localhost:5173
# Euclidean distance: lower = stricter match (typical 0.5–0.65)
FACE_MATCH_THRESHOLD=0.55
# Reject registration if closest existing face is closer than this
DUPLICATE_FACE_THRESHOLD=0.45
# SSD face detector minimum score (0–1)
MIN_DETECTION_CONFIDENCE=0.5
